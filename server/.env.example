# Copy this file to .env and fill in all values before going live.
# NEVER commit .env to source control.

PORT=5001
NODE_ENV=production

# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-character-hex-string

JWT_EXPIRES_IN=8h

# Path to the SQLite database file (relative to server/)
DB_PATH=./db/ehr.db

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://app.yourclinic.com,https://www.yourclinic.com
ALLOWED_ORIGINS=https://your-frontend-domain.com
