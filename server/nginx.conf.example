# ─────────────────────────────────────────────────────────────────────────────
# Nginx configuration for the Clarity EHR — Cloudflare + Origin Server
#
# Architecture:
#   Browser → Cloudflare (TLS, CDN, DDoS) → this server (Nginx → Express)
#
# Cloudflare dashboard settings required:
#   1. SSL/TLS mode: "Full (strict)"  ← NOT "Flexible"
#   2. Both DNS records set to "Proxied" (orange cloud)
#   3. Under Rules → Page Rules (or Transform Rules): no HTTP→HTTPS needed
#      since Cloudflare handles that — but we keep it here as a fallback.
#
# Origin certificate options (pick one):
#   A. Cloudflare Origin Certificate (free, 15-year):
#      Dashboard → SSL/TLS → Origin Server → Create Certificate
#      Save cert + key to the paths below.
#   B. Let's Encrypt via Certbot (if you ever go DNS-only):
#      sudo certbot --nginx -d app.clarity-ehr.com -d api.clarity-ehr.com
#
# After editing:
#   sudo nginx -t && sudo systemctl reload nginx
# ─────────────────────────────────────────────────────────────────────────────

# ── Trust Cloudflare IPs so real_ip / req.ip works correctly ─────────────────
# Cloudflare publishes its IP ranges at https://www.cloudflare.com/ips/
# Update this list when Cloudflare publishes new ranges (rare).
geo $cloudflare_ip {
    default          0;
    # IPv4
    173.245.48.0/20  1;
    103.21.244.0/22  1;
    103.22.200.0/22  1;
    103.31.4.0/22    1;
    141.101.64.0/18  1;
    108.162.192.0/18 1;
    190.93.240.0/20  1;
    188.114.96.0/20  1;
    197.234.240.0/22 1;
    198.41.128.0/17  1;
    162.158.0.0/15   1;
    104.16.0.0/13    1;
    104.24.0.0/14    1;
    172.64.0.0/13    1;
    131.0.72.0/22    1;
    # IPv6
    2400:cb00::/32   1;
    2606:4700::/32   1;
    2803:f800::/32   1;
    2405:b500::/32   1;
    2405:8100::/32   1;
    2a06:98c0::/29   1;
    2c0f:f248::/32   1;
}

# Replace $remote_addr with the real visitor IP from the CF-Connecting-IP header,
# but ONLY when the request actually comes from a Cloudflare IP.
map $cloudflare_ip $real_client_ip {
    1       $http_cf_connecting_ip;
    default $remote_addr;
}

# Redirect all HTTP → HTTPS (fallback — Cloudflare handles this in front)
server {
    listen 80;
    listen [::]:80;
    server_name app.clarity-ehr.com api.clarity-ehr.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── Frontend (React SPA) ──────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name app.clarity-ehr.com;

    # TLS — use Cloudflare Origin Certificate (recommended) or Let's Encrypt
    ssl_certificate     /etc/ssl/cloudflare/origin.pem;
    ssl_certificate_key /etc/ssl/cloudflare/origin.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;

    # Security headers
    # Note: Cloudflare also adds HSTS — setting it here ensures the origin→CF leg is covered too
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    # Content-Security-Policy — tighten after testing
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://api.clarity-ehr.com https://sentry.io;" always;

    # Serve the Vite dist build
    root /var/www/ehr/dist;
    index index.html;

    # Gzip (Cloudflare also compresses, but this handles the origin→CF leg)
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    gzip_min_length 1000;

    # Cache static assets aggressively (Vite fingerprints filenames — safe to cache forever)
    # alias maps /Clarity/static/ → /var/www/ehr/dist/static/ (Vite builds assets here, not under Clarity/)
    location /Clarity/static/ {
        alias /var/www/ehr/dist/static/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # React Router — all /Clarity/* paths fallback to index.html
    location /Clarity/ {
        try_files $uri $uri/ /index.html;
    }

    location = / {
        return 301 /Clarity/;
    }
}

# ── Backend API ───────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.clarity-ehr.com;

    ssl_certificate     /etc/ssl/cloudflare/origin.pem;
    ssl_certificate_key /etc/ssl/cloudflare/origin.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;

    # Body size limit (matches Express limit for document uploads)
    client_max_body_size 10M;

    location /api/ {
        proxy_pass         http://127.0.0.1:5001;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;

        # Pass the real visitor IP (resolved from CF-Connecting-IP above)
        proxy_set_header   X-Real-IP         $real_client_ip;
        proxy_set_header   X-Forwarded-For   $real_client_ip;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Pass Cloudflare metadata — useful for logging and geo-blocking
        proxy_set_header   CF-Connecting-IP  $http_cf_connecting_ip;
        proxy_set_header   CF-IPCountry      $http_cf_ipcountry;
        proxy_set_header   CF-Ray            $http_cf_ray;

        # WebSocket support (for future use)
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";

        # Timeouts
        proxy_connect_timeout 10s;
        proxy_read_timeout    60s;
        proxy_send_timeout    60s;
    }

    # Block anything that isn't an API path
    location / {
        return 404;
    }
}
