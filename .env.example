# Copy to .env.local for local development (Vite ignores .env.local in git).
# For production builds, set VITE_API_URL to your backend server URL.

# Leave empty in development — the Vite proxy forwards /api/* to localhost:5001
VITE_API_URL=

# Production example:
# VITE_API_URL=https://api.yourclinic.com/api
