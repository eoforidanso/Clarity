# Copy to .env.local for local development (Vite ignores .env.local in git).
# For production builds, set VITE_API_URL to your backend server URL.

# Leave empty in development — the Vite proxy forwards /api/* to localhost:5001
VITE_API_URL=

# Production example:
# VITE_API_URL=https://api.yourclinic.com/api

# Auto-response engine
AUTO_RESPONSE_ENABLED=true
AUTO_RESPONSE_MODE=shadow   # shadow | enforce

# Database Backups (DO Spaces / S3-compatible)
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
SPACES_BUCKET=clarity-ehr-backups
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
BACKUP_RETAIN_DAYS=30
