# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION BUILD CONFIG
#
# VITE_API_URL must stay as /api
#
# Why: The Cloudflare Pages function at functions/api/[[path]].js proxies
# all /api/* requests to https://api.clarity-ehr.com on the same origin,
# so cookies work and there are no CORS issues.
#
# If you set this to https://api.clarity-ehr.com the browser will make
# cross-origin requests, cookies will be blocked, and login will fail.
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=/api

# LiveKit Cloud (https://cloud.livekit.io) — create a free project, copy the WSS URL
# Example: VITE_LIVEKIT_URL=wss://clarity-ehr-41bwwgzg.livekit.cloudwss://your-project.livekit.cloud
# Leave blank until you have a LiveKit project configured — video falls back gracefully
VITE_LIVEKIT_URL=wss://clarity-ehr-41bwwgzg.livekit.cloud
